from google import genai
import json
import re
client = genai.Client(api_key="My_key")
image_path = "phy.png"
my_file = client.files.upload(file=image_path)
prompt = {
        """"You are a strict formatting engine. You MUST follow the output format exactly. You are NOT allowed to add, remove, or modify the format in any way.",
        "Generate 5 questions based on the image provided. The questions should be of varying difficulty levels.",
        Output must contain exactly 2 sections:
                QUESTIONS
                ANSWERS
            QUESTIONS section:
                Exactly 5 lines
                Format:
                Q1. <question>
                Q2. <question>
                Q3. <question>
                Q4. <question>
                Q5. <question>
            ANSWERS section:
                Must start with EXACT text: answers:
                Exactly 5 lines after that
                    Format:
                        q1. keyword1, keyword2, keyword3
                        q2. keyword1, keyword2, keyword3
                        q3. keyword1, keyword2, keyword3
                        q4. keyword1, keyword2, keyword3
                        q5. keyword1, keyword2, keyword3
        Keywords MUST be comma-separated
                        No sentences in answers
                        No extra explanations
                        No blank lines
                        No bullets
                        No markdown
                        No headings
                        No additional text before or after
                        Each question MUST be on a single line
                        Each answer MUST be on a single line
                        There must be NO empty lines anywhere
                        There must be NO text before Q1
                        There must be NO text after q5"""

}
response = client.models.generate_content(
    model="gemini-3-flash-preview",
    contents=[my_file, prompt]
)
to_pass = response.text[0:response.text.find('answers:')]
answer = response.text[response.text.find('answers:'):]
print(to_pass)

with open("image_ques.json", "w") as f:
    json.dump(response.text,f)

text = response.text.lower()

# ---- split into question part and answer part ----
split_point = text.find("answers:")
questions_part = text[:split_point]
answers_part = text[split_point:]

# ---- convert to lists ----
questions = [q.strip() for q in questions_part.split("\n") if q.strip()]
answers = [a.strip() for a in answers_part.split("\n") if a.strip()]

# remove "answers:" line
answers = answers[1:]

# ---- loop through each question ----
for i in range(min(len(questions), len(answers))):
    
    print("\nQuestion:", questions[i])
    
    user_ans = input("Your answer:").lower()
    
    # ---- extract keywords ----
    line = answers[i]
    
    # remove "q1.", "q2." etc
    line = re.sub(r'q\d+\.', '', line)
    
    keywords = [k.strip() for k in line.split(",") if k.strip()]
    
    # ---- matching ----
    score = 0
    
    for k in keywords:
        if k in user_ans:
            score += 1
    
    total = len(keywords)
    
    print("Score:", score, "/", total)

